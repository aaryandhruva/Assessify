# Assessify — environment variables template
# Copy to .env.local and fill in real values before deploying.

# Analytics (placeholder IDs — replace with your own)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_VERCEL_ANALYTICS=1

# Contact form endpoint (e.g. Formspree, Resend, or your API route)
NEXT_PUBLIC_CONTACT_ENDPOINT=https://example.com/api/contact

# Site
NEXT_PUBLIC_SITE_URL=https://assessify.ai
